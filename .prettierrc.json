{
    "printWidth": 300,
    "useTabs": false,
    "arrowParens": "avoid",
    "singleQuote": false,
    "semi": false,
    "trailingComma": "all",
    "endOfLine": "auto",
    "tabWidth": 4,
    "bracketSpacing": true,
    "bracketSameLine": false,
    "singleAttributePerLine": false,
    "htmlWhitespaceSensitivity": "ignore"
}
